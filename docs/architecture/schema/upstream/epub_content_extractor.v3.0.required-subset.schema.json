{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deszo.local/schema/upstream/epub_content_extractor.v3.0.required-subset.schema.json",
  "title": "Consumed required subset of epub_content_extractor.v3.0 for stanza_annotator",
  "description": "This is not the complete upstream extractor schema. It is the strict boundary schema for fields stanza_annotator reads, copies, fingerprints, or uses for content selection.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "status"
  ],
  "properties": {
    "schema_version": {
      "const": "epub_content_extractor.v3.0"
    },
    "status": {
      "enum": [
        "succeeded",
        "failed"
      ]
    },
    "book": {
      "$ref": "#/$defs/EpubBook"
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "default": []
    },
    "extraction": {
      "$ref": "#/$defs/EpubExtractionInfo"
    },
    "error": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "succeeded"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "book",
          "diagnostics",
          "extraction"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "failed"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "diagnostics",
          "extraction"
        ]
      }
    }
  ],
  "$defs": {
    "NullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "Person": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        }
      }
    },
    "EpubSourceFile": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "file_name"
      ],
      "properties": {
        "file_name": {
          "type": "string",
          "minLength": 1,
          "not": {
            "anyOf": [
              {
                "pattern": "(^/|^[A-Za-z]:|[\\\\/]|\\.\\.)"
              },
              {
                "pattern": "[\\u0000-\\u001F\\u007F]"
              }
            ]
          }
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "epub_version": {
          "type": "string"
        }
      }
    },
    "EpubMetadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "identifiers": {
          "type": "array"
        },
        "publisher": {
          "type": [
            "string",
            "null"
          ]
        },
        "published_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "modified_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "rights": {
          "type": [
            "string",
            "null"
          ]
        },
        "subjects": {
          "type": "array"
        },
        "source_file": {
          "$ref": "#/$defs/EpubSourceFile"
        }
      }
    },
    "EpubParagraph": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "text"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "paragraph_number": {
          "type": "integer",
          "minimum": 1
        },
        "text": {
          "type": "string"
        }
      }
    },
    "EpubFootnote": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "text"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "marker": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "paragraph_number": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "EpubSection": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "type",
        "text",
        "paragraphs",
        "footnotes",
        "included_in_canonical_text"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string"
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "text": {
          "type": "string"
        },
        "paragraphs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EpubParagraph"
          }
        },
        "footnotes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EpubFootnote"
          },
          "default": []
        },
        "included_in_canonical_text": {
          "type": "boolean"
        }
      },
      "description": "Consumed front/back matter section shape. The upstream v3.0 public fields needed for structural copy-through are required; selectable text may be an empty string and is skipped later with text_unit_empty when selected."
    },
    "EpubChapter": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "chapter_number",
        "type",
        "text",
        "footnotes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "chapter_number": {
          "type": "integer",
          "minimum": 1
        },
        "type": {
          "type": "string"
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "text": {
          "type": "string"
        },
        "footnotes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EpubFootnote"
          },
          "default": []
        },
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EpubSection"
          },
          "default": []
        }
      },
      "description": "Consumed v3.0 chapter shape. stanza_annotator does not synthesize missing chapter_number, type, or footnotes; schema-valid consumed input must provide the public upstream fields required to copy a chapter into AnnotatedEpubChapter. chapter.text is required and chapters[].paragraphs is forbidden by the upstream production schema.",
      "allOf": [
        {
          "not": {
            "required": [
              "paragraphs"
            ]
          }
        }
      ]
    },
    "EpubBook": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "title",
        "subtitle",
        "language",
        "authors",
        "contributors",
        "metadata",
        "front_matter",
        "chapters",
        "back_matter",
        "footnotes",
        "table_of_contents",
        "assets"
      ],
      "properties": {
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "subtitle": {
          "type": [
            "string",
            "null"
          ]
        },
        "language": {
          "const": "en"
        },
        "authors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Person"
          },
          "default": []
        },
        "contributors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Person"
          },
          "default": []
        },
        "metadata": {
          "$ref": "#/$defs/EpubMetadata"
        },
        "chapters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EpubChapter"
          }
        },
        "front_matter": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EpubSection"
          }
        },
        "back_matter": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EpubSection"
          }
        },
        "footnotes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EpubFootnote"
          }
        },
        "table_of_contents": {
          "type": "array"
        },
        "assets": {
          "type": "array"
        }
      }
    },
    "EpubExtractionConfig": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "include_front_matter_in_canonical_text",
        "include_back_matter_in_canonical_text",
        "include_footnotes_in_canonical_text",
        "include_chapter_titles_in_canonical_text",
        "include_section_titles_in_canonical_text"
      ],
      "properties": {
        "include_front_matter_in_canonical_text": {
          "type": "boolean"
        },
        "include_back_matter_in_canonical_text": {
          "type": "boolean"
        },
        "include_footnotes_in_canonical_text": {
          "type": "boolean"
        },
        "include_chapter_titles_in_canonical_text": {
          "type": "boolean"
        },
        "include_section_titles_in_canonical_text": {
          "type": "boolean"
        }
      }
    },
    "EpubExtractionSummary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "chapter_count",
        "front_matter_section_count",
        "back_matter_section_count",
        "paragraph_count",
        "footnote_count",
        "total_text_chars",
        "canonical_text_chars",
        "warning_count",
        "error_count"
      ],
      "properties": {
        "chapter_count": {
          "type": "integer",
          "minimum": 0
        },
        "front_matter_section_count": {
          "type": "integer",
          "minimum": 0
        },
        "back_matter_section_count": {
          "type": "integer",
          "minimum": 0
        },
        "paragraph_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Counts only emitted EpubParagraph objects in front_matter/back_matter in upstream v3.0; chapter paragraph-like units are internal and not exposed."
        },
        "footnote_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_text_chars": {
          "type": "integer",
          "minimum": 0
        },
        "canonical_text_chars": {
          "type": "integer",
          "minimum": 0
        },
        "removed_section_count": {
          "type": "integer",
          "minimum": 0
        },
        "warning_count": {
          "type": "integer",
          "minimum": 0
        },
        "error_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "EpubExtractionInfo": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "extractor_version",
        "config",
        "summary"
      ],
      "properties": {
        "extractor_version": {
          "type": "string",
          "minLength": 1
        },
        "config": {
          "$ref": "#/$defs/EpubExtractionConfig"
        },
        "summary": {
          "$ref": "#/$defs/EpubExtractionSummary"
        }
      }
    }
  },
  "x-limitation": "Consumed-boundary schema only. Replace with the full upstream schema when available, but do not weaken the consumed-field invariants defined here.",
  "x-contract-notes": [
    "Duplicate IDs across chapters/sections/footnotes/paragraph-derived text units are contract violations checked by implementation contract tests; JSON Schema cannot express all cross-array uniqueness constraints portably."
  ]
}
