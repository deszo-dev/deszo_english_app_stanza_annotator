    "EffectiveStanzaAnnotatorConfigSnapshot": {
      "allOf": [
        {
          "$ref": "https://deszo.local/schema/stanza_annotator_config.v2.0.schema.json"
        },
        {
          "not": {
            "required": [
              "debug_dir"
            ]
          }
        }
      ],
      "required": [
        "language",
        "processors",
        "use_gpu",
        "tokenize_pretokenized",
        "auto_download",
        "content_selection",
        "batch_size",
        "max_text_unit_chars",
        "max_output_json_bytes",
        "include_debug",
        "logging"
