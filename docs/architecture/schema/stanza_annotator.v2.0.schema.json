      "properties": {
        "content_selection": {
          "required": [
            "mode",
            "include_chapters",
            "include_front_matter",
            "include_back_matter",
            "include_footnotes",
            "include_chapter_titles",
            "include_section_titles"
          ]
        },
        "logging": {
          "required": [
            "enabled",
            "level"
          ]
        }
      },
      "description": "Fully materialized production-safe config snapshot emitted under annotation.config. CLI-only debug_dir is forbidden here. All behavior-affecting defaults MUST be present."
